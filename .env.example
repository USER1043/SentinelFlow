# AlloyDB Configuration
# Use format: project_id:region:instance (e.g., my-project:us-central1:my-instance)
INSTANCE_CONNECTION_NAME=project_id:region:instance
PROJECT_ID=project_id
DB_USER=postgres
DB_PASS=your_database_password
DB_NAME=sentinelflow

# Optional Settings
PORT=8080
SQL_ECHO=false

# Authentication: Uses Application Default Credentials (ADC)
# Set via: gcloud auth application-default login
# No manual credentials file needed!
